# A bash in_array.
# array=(one two three); contains one $array && echo 'yes' || echo 'no'
# Outputs 'yes'
contains () {
	param=$1;
	shift;
	for elem in "$@";
	do
		[[ "$param" = "$elem" ]] && return 0;
	done;
	return 1
}

