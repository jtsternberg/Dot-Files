generate-key() {
	LENGTH=${1:-34}
	ALPHANUMERIC_ONLY=${2}
	KEY=$(php -r "
	\$chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
	if (! '$ALPHANUMERIC_ONLY' ) {
		\$chars .= '\!\@#\$%^&*()_+-=[]{}|;:,.<>?/\~';
	}
	\$length = $LENGTH;
	\$key = '';
	for (\$i = 0; \$i < \$length; \$i++) {
		\$key .= \$chars[random_int(0, strlen(\$chars) - 1)];
	}
	echo \$key . PHP_EOL;
	")
	CAN_COPY=$(command -v pbcopy)
	if [ -n "$CAN_COPY" ]; then
		echo "$KEY" | tr -d '\n' | pbcopy;
		echo "$KEY\nLength: ${#KEY} (Copied to clipboard)";
	else
		echo "$KEY\n(length: ${#KEY})";
	fi
}

