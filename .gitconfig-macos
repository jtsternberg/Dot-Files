; macOS-specific git configuration
; Loaded via [include] path = ~/.gitconfig-local (symlinked by symdotfiles)

[credential]
	helper = osxkeychain

[safe]
	directory = /private/etc/apache2

[diff]
	tool = Kaleidoscope

[difftool "Kaleidoscope"]
	cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"

[difftool "sourcetree"]
	cmd = /usr/local/bin/ksdiff -w \"$LOCAL\" \"$REMOTE\"
	path =

[merge]
	tool = Kaleidoscope

[mergetool "Kaleidoscope"]
	cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
	trustExitCode = true

; SSH commit signing via a dedicated passphraseless on-disk key (headless-safe).
; 1Password remains the *auth* key (git push over SSH); signing was moved off
; 1P because op-ssh-sign requires the 1P app unlocked (biometric), which blocks
; all commits during remote/headless sessions.
;
; New-machine setup:
;   1. ssh-keygen -t ed25519 -f ~/.ssh/git_signing -C "git signing (headless)" -N ""
;   2. Add ~/.ssh/git_signing.pub at https://github.com/settings/ssh/new with
;      Key type = "Signing Key". The committer email must be a *verified* email
;      on that account for the "Verified" badge.
;      Or: gh api user/ssh_signing_keys -f title="..." -f key="$(cat ~/.ssh/git_signing.pub)"
;   3. Append the new pubkey to ~/.dotfiles/git-allowed-signers.
; Trade-off: key is unencrypted on disk (FileVault covers at-rest); it can only
; sign, never authenticate — no repo/server access if lifted.
[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.dotfiles/git-allowed-signers

[user]
	signingkey = ~/.ssh/git_signing

[commit]
	gpgsign = true

[tag]
	gpgsign = true
