; macOS-specific git configuration
; Loaded via [include] path = ~/.gitconfig-local (symlinked by symdotfiles)

[credential]
	helper = osxkeychain

[safe]
	directory = /private/etc/apache2

[diff]
	tool = Kaleidoscope

[difftool "Kaleidoscope"]
	cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"

[difftool "sourcetree"]
	cmd = /usr/local/bin/ksdiff -w \"$LOCAL\" \"$REMOTE\"
	path =

[merge]
	tool = Kaleidoscope

[mergetool "Kaleidoscope"]
	cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
	trustExitCode = true

; SSH commit signing via 1Password (macOS-only: op-ssh-sign path).
; Linux needs its own signer config in .gitconfig-linux.
;
; New-machine setup (one GUI step; everything else is in this repo):
;   1. 1Password app -> Settings -> Developer -> "Use the SSH agent" (toggle on).
;      op-ssh-sign needs the agent running to reach the key.
;   2. (per GitHub account, already done for jtsternberg) Add the public key at
;      https://github.com/settings/ssh/new with Key type = "Signing Key".
;      The committer email must be a *verified* email on that account for the
;      "Verified" badge. Key lives in 1Password ("Github SSH Key").
; The signing key + allowed-signers list are tracked in the repo, so no other
; manual steps: signingkey below, and git-allowed-signers (allowedSignersFile).
[gpg]
	format = ssh

[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
	allowedSignersFile = ~/.dotfiles/git-allowed-signers

[user]
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJswq85xKah+wqtOahkzEWDtMTOSj4hqMhmS751hiUJu

[commit]
	gpgsign = true

[tag]
	gpgsign = true
