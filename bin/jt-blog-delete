#!/usr/bin/env php
<?php

// Deletes a blog post from jtsternberg.com.

namespace JT\CLI;

require_once dirname( __DIR__ ) . '/vendor/autoload.php';

$cli = getCli( $argv );

use JT\CLI\Commands\SiteCommand;

$helpyHelperton = $cli->getHelp();

$helpyHelperton
	->setScriptName( 'jt-blog-delete' )
	->setPrefix( '' )
	->setDescription( 'Deletes a blog post or page from jtsternberg.com.' )
	->setSampleUsage( '<post-id|slug> [--force] [--page]' )
	->buildDocs( [
		'<post-id|slug>'  => 'Post or page ID or slug to delete (required)',
		'--force'         => 'Permanently delete (bypass trash)',
		'--page'          => 'Delete from pages endpoint instead of posts',
		'--url=DOMAIN'    => 'Target a different site (e.g. coaching.jtsternberg.com)',
	] );

if ( $helpyHelperton->batSignal ) {
	$cli->msg( $helpyHelperton->getHelp() );
	exit( 0 );
}

class BlogDeleteCommand extends SiteCommand {

	protected $postId;
	protected $postSlug;
	protected $force = false;
	protected $isPage = false;

	public function __construct( $cli ) {
		$this->isPage = $cli->hasFlag( 'page' );
		parent::__construct( $cli );

		// Get post ID/slug from flag or positional argument
		$postIdentifier = $cli->getFlag( 'postId' ) ?: $cli->getArg( 1 );

		if ( empty( $postIdentifier ) ) {
			throw new \Exception( "Error: Post or page ID or slug is required." );
		}

		// If numeric, treat as ID; otherwise treat as slug
		if ( is_numeric( $postIdentifier ) ) {
			$this->postId = (int) $postIdentifier;
		} else {
			$this->postSlug = $postIdentifier;
		}

		$this->force = $cli->hasFlag( 'force' );
	}

	protected function getEntityLabel(): string {
		return $this->isPage ? 'page' : 'post';
	}

	/**
	 * Override to add REST URL with /posts or /pages endpoint.
	 */
	protected function getRestUrl(): ?string {
		$baseUrl = parent::getRestUrl();
		if ( $baseUrl ) {
			$resource = $this->isPage ? 'pages' : 'posts';
			return rtrim( $baseUrl, '/' ) . '/' . $resource;
		}
		return null;
	}

	/**
	 * Resolve a post or page slug to its ID.
	 */
	protected function resolveSlugToId( string $slug ): int {
		$baseUrl = $this->resolveRestUrl();
		$url = rtrim( $baseUrl, '/' ) . '?slug=' . urlencode( $slug ) . '&status=any';

		$posts = $this->executeRequest( $url, 'GET' );

		if ( empty( $posts ) ) {
			$label = $this->getEntityLabel();
			throw new \Exception( "Error: No {$label} found with slug '{$slug}'" );
		}

		return (int) $posts[0]['id'];
	}

	/**
	 * Delete the post or page.
	 */
	protected function deletePost(): array {
		$baseUrl = $this->resolveRestUrl();
		$url = rtrim( $baseUrl, '/' ) . '/' . $this->postId;

		if ( $this->force ) {
			$url .= '?force=true';
		}

		return $this->executeRequest( $url, 'DELETE' );
	}

	public function run(): void {
		$label = ucfirst( $this->getEntityLabel() );
		$intro = $this->isPage ? 'page' : 'blog post';
		$site = $this->restUrl ? parse_url( $this->restUrl, PHP_URL_HOST ) : 'jtsternberg.com';
		$this->cli->msg( "Deleting {$intro} from {$site}...\n", 'yellow' );

		// Load environment variables
		$this->loadEnv();

		// Set credentials from ENV
		$this->setCredentials();

		// Resolve slug to ID if needed
		if ( ! empty( $this->postSlug ) ) {
			$this->cli->msg( "Looking up {$this->getEntityLabel()} by slug: {$this->postSlug}...\n" );
			$this->postId = $this->resolveSlugToId( $this->postSlug );
		}

		$this->cli->msg( "Deleting {$this->getEntityLabel()} ID: {$this->postId}...\n" );

		$result = $this->deletePost();

		$title = $result['title']['rendered'] ?? $result['title']['raw'] ?? null;

		if ( $this->force ) {
			$msg = $title ? "{$label} permanently deleted: {$title}" : "{$label} permanently deleted.";
			$this->cli->msg( "\n✓ {$msg}\n", 'green' );
		} else {
			$msg = $title ? "{$label} moved to trash: {$title}" : "{$label} moved to trash.";
			$this->cli->msg( "\n✓ {$msg}\n", 'green' );
		}
	}
}

try {
	$cmd = new BlogDeleteCommand( $cli );
	$cmd->run();
} catch ( \Exception $e ) {
	$cli->err( "\n{$e->getMessage()}\n" );
	exit( 1 );
}
