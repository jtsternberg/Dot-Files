#!/usr/bin/env bash
# Deprecated alias — renamed to `system-watchdog` (now covers CPU + memory +
# battery, not just power). Forwards to the new command; remove this shim once
# muscle memory catches up.
echo "note: 'battery-watchdog' is now 'system-watchdog' — forwarding." >&2
exec "$(dirname "$0")/system-watchdog" "$@"
