#!/usr/bin/env bash
# =============================================================================
# notes-dropbox-sync
# Cross-platform 2-way sync helper for the Obsidian remotely-save plugin.
# When Obsidian isn't running, remotely-save can't sync — this fills the gap:
#
#   Notes → Dropbox: picks up changes from git, CLI, or the Telegram bot
#   Dropbox → Notes: picks up changes made on mobile, then commits to git
#
# Loop prevention: each sync direction stamps a lock file. The other watcher
# checks the lock and skips if the event is just an echo of our own sync.
#
# Works on macOS and Linux.
#
# Prerequisites:
#   macOS:  brew install fswatch
#   Linux:  sudo apt install inotify-tools
#   Both:   Dropbox daemon running, Obsidian vault at ~/Documents/Notes
#
# Setup:
#   macOS (launchd) — run once:
#     cp ~/.dotfiles/notes-dropbox-sync/notes-dropbox-sync.plist ~/Library/LaunchAgents/
#     launchctl load ~/Library/LaunchAgents/notes-dropbox-sync.plist
#     launchctl start notes-dropbox-sync
#
#   Linux (systemd) — run once:
#     ln -s ~/.dotfiles/notes-dropbox-sync/notes-dropbox-sync.service ~/.config/systemd/user/
#     systemctl --user daemon-reload
#     systemctl --user enable --now notes-dropbox-sync
#
# Configuration (~/.config/notes-dropbox-sync/config):
#   SYNC_NOTES_TO_DROPBOX=true   # watch Notes, push to Dropbox
#   SYNC_DROPBOX_TO_NOTES=true   # watch Dropbox, pull into Notes + git commit
#   Both default to true if unset. Set to "false" to disable a direction.
#
# Usage:
#   notes-dropbox-sync        (run directly, or via launchd/systemd)
# =============================================================================

# Defaults — override per-machine via config file
SYNC_NOTES_TO_DROPBOX=true
SYNC_DROPBOX_TO_NOTES=true
DELETE_GRACE=30  # seconds to wait before propagating Dropbox→Notes deletions
                 # (covers transient MOVED_FROM windows from remotely-save/Dropbox writes)
MAX_DELETE=3     # refuse Dropbox→Notes sync that would delete more than this many files
                 # (safety brake: bulk phone deletions are rare; large counts almost always
                 # mean Dropbox state is glitched, not user intent)

CONFIG="$HOME/.config/notes-dropbox-sync/config"
[[ -f "$CONFIG" ]] && source "$CONFIG"

SOURCE="$HOME/Documents/Notes"
COOLDOWN=10  # seconds to suppress echo direction after a sync

# Lock files — one per direction
LOCK_N2D="/tmp/notes-dropbox-sync-n2d"  # written when Notes→Dropbox fires
LOCK_D2N="/tmp/notes-dropbox-sync-d2n"  # written when Dropbox→Notes fires

# Common rsync excludes
EXCLUDES=(
	--exclude='.git'
	--exclude='.claude'
	--exclude='.fb-review-profile'
	--exclude='.mcp.json'
	--exclude='.DS_Store'
	--exclude='*.orig'
)

# Detect Dropbox root — newer macOS moves it to CloudStorage
if [[ -d "$HOME/Library/CloudStorage/Dropbox" ]]; then
	DROPBOX_ROOT="$HOME/Library/CloudStorage/Dropbox"
elif [[ -d "$HOME/Dropbox" ]]; then
	DROPBOX_ROOT="$HOME/Dropbox"
else
	echo "Dropbox folder not found." >&2
	exit 1
fi

DEST="$DROPBOX_ROOT/Apps/remotely-save/Notes"

is_recent() {
	local lockfile="$1"
	[[ -f "$lockfile" ]] || return 1
	local last now
	last=$(cat "$lockfile")
	now=$(date +%s)
	(( now - last < COOLDOWN ))
}

sync_notes_to_dropbox() {
	date +%s > "$LOCK_N2D"
	rsync -rlt --delete --no-perms \
		"${EXCLUDES[@]}" \
		"$SOURCE/" "$DEST/"
	echo "Notes→Dropbox synced: $(date)"
}

sync_dropbox_to_notes() {
	date +%s > "$LOCK_D2N"

	# Pass 1 — copy/update only. NEVER delete on this pass; if Dropbox is mid-write
	# (MOVED_FROM without yet-arrived MOVED_TO) we don't want to amplify it into Notes.
	rsync -rlt --no-perms \
		"${EXCLUDES[@]}" \
		"$DEST/" "$SOURCE/"
	date +%s > "$LOCK_D2N"

	# Are there any deletion candidates? (files in Notes that aren't in Dropbox)
	local pending
	pending=$(rsync -rlt --delete --dry-run --no-perms \
		"${EXCLUDES[@]}" \
		"$DEST/" "$SOURCE/" 2>/dev/null \
		| grep -c '^deleting ')

	if (( pending > MAX_DELETE )); then
		echo "Dropbox→Notes: REFUSING to delete $pending file(s); exceeds MAX_DELETE=$MAX_DELETE. Investigate Dropbox state. Skipping deletion pass." >&2
	elif (( pending > 0 )); then
		echo "Dropbox→Notes: $pending deletion(s) pending; waiting ${DELETE_GRACE}s grace period to confirm..."
		# Slice the sleep so we keep LOCK_D2N fresh (well under COOLDOWN=$COOLDOWN)
		# Otherwise the Notes watcher could see pass 1's writes as "not echo" and
		# fight us during the grace window.
		local elapsed=0 step=5
		while (( elapsed < DELETE_GRACE )); do
			sleep "$step"
			elapsed=$(( elapsed + step ))
			date +%s > "$LOCK_D2N"
		done

		# Re-check: did the missing files reappear in Dropbox during the grace window?
		local pending_after
		pending_after=$(rsync -rlt --delete --dry-run --no-perms \
			"${EXCLUDES[@]}" \
			"$DEST/" "$SOURCE/" 2>/dev/null \
			| grep -c '^deleting ')

		if (( pending_after == 0 )); then
			echo "Dropbox→Notes: deletion candidates reappeared in Dropbox; no deletions needed."
		elif (( pending_after > MAX_DELETE )); then
			echo "Dropbox→Notes: REFUSING to delete $pending_after file(s) after grace window; exceeds MAX_DELETE=$MAX_DELETE. Skipping deletion pass." >&2
		else
			echo "Dropbox→Notes: confirming $pending_after deletion(s) after grace window."
			date +%s > "$LOCK_D2N"
			rsync -rlt --delete --no-perms \
				"${EXCLUDES[@]}" \
				"$DEST/" "$SOURCE/"
		fi
	fi

	date +%s > "$LOCK_D2N"
	echo "Dropbox→Notes synced: $(date)"

	# Commit any changes to git
	cd "$SOURCE" || return
	if [ -n "$(git status --porcelain)" ]; then
		git add -A
		git commit -m "sync: notes from phone via dropbox"
		git push
		echo "Git commit + push complete: $(date)"
	fi
}

watch_notes() {
	echo "Watching Notes ($SOURCE)..."
	while true; do
		inotifywait -r -q -e close_write,create,delete,move \
			--exclude '(\.git|\.obsidian)' \
			"$SOURCE"
		sleep 2  # debounce
		if is_recent "$LOCK_D2N"; then
			echo "Notes watcher: skipping (Dropbox→Notes was recent, avoiding echo)"
		else
			echo "Notes watcher: change detected, syncing Notes→Dropbox"
			sync_notes_to_dropbox
		fi
	done
}

watch_dropbox() {
	echo "Watching Dropbox ($DEST)..."
	while true; do
		inotifywait -r -q -e close_write,create,delete,move "$DEST"
		sleep 2  # debounce
		if is_recent "$LOCK_N2D"; then
			echo "Dropbox watcher: skipping (Notes→Dropbox was recent, avoiding echo)"
		else
			echo "Dropbox watcher: change detected, syncing Dropbox→Notes"
			sync_dropbox_to_notes
		fi
	done
}

watch_notes_mac() {
	echo "Watching Notes ($SOURCE)..."
	fswatch -r "$SOURCE" | while read -r; do
		sleep 2  # debounce
		if is_recent "$LOCK_D2N"; then
			echo "Notes watcher: skipping (Dropbox→Notes was recent, avoiding echo)"
		else
			echo "Notes watcher: change detected, syncing Notes→Dropbox"
			sync_notes_to_dropbox
		fi
	done
}

watch_dropbox_mac() {
	echo "Watching Dropbox ($DEST)..."
	fswatch -r "$DEST" | while read -r; do
		sleep 2  # debounce
		if is_recent "$LOCK_N2D"; then
			echo "Dropbox watcher: skipping (Notes→Dropbox was recent, avoiding echo)"
		else
			echo "Dropbox watcher: change detected, syncing Dropbox→Notes"
			sync_dropbox_to_notes
		fi
	done
}

cleanup() {
	echo "Shutting down..."
	kill 0
	exit 0
}
trap cleanup SIGINT SIGTERM

if [[ "$SYNC_NOTES_TO_DROPBOX" != "true" && "$SYNC_DROPBOX_TO_NOTES" != "true" ]]; then
	echo "Both sync directions disabled in $CONFIG — nothing to do." >&2
	exit 1
fi

echo "Sync config: Notes→Dropbox=$SYNC_NOTES_TO_DROPBOX, Dropbox→Notes=$SYNC_DROPBOX_TO_NOTES"

if [[ "$OSTYPE" == "darwin"* ]]; then
	if ! command -v fswatch &>/dev/null; then
		echo "fswatch not found. Install via Homebrew: brew install fswatch" >&2
		exit 1
	fi
	[[ "$SYNC_NOTES_TO_DROPBOX" == "true" ]] && watch_notes_mac &
	[[ "$SYNC_DROPBOX_TO_NOTES" == "true" ]] && watch_dropbox_mac &
else
	if ! command -v inotifywait &>/dev/null; then
		echo "inotifywait not found. Install via: sudo apt install inotify-tools" >&2
		exit 1
	fi
	[[ "$SYNC_NOTES_TO_DROPBOX" == "true" ]] && watch_notes &
	[[ "$SYNC_DROPBOX_TO_NOTES" == "true" ]] && watch_dropbox &
fi

wait
