#!/usr/bin/env php
<?php
namespace JT;
# =============================================================================
# Backup and restore cmux workspace/session state
# By Justin Sternberg <me@jtsternberg.com>
#
# Version 0.2.0
#
# Saves all cmux workspaces, panes, and surfaces to ~/.config/cmux/bak.json,
# capturing each terminal's CWD and any active Claude Code session ID.
#
# Session IDs come from ~/.claude/sessions/<pid>.json — no screen-scraping.
#
# On --restore, audits existing workspaces by name and only acts on what's
# missing: resumes dead Claude sessions in existing workspaces, and recreates
# workspaces that are gone entirely.
#
# `audit` is a read-only diff: it compares the backup's Claude sessions against
# what's actually running now (matched by session id via the deterministic
# session↔surface join) and reports which conversations did not re-open — then
# offers to resume the missing ones into their existing surfaces.
#
# Usage:
# cmux-bak [--restore] [--file=<path>] [--dry-run] [--verbose]
# cmux-bak audit [--file=<path>] [--dry-run] [--verbose]
# =============================================================================

$cli = require_once dirname(__DIR__) . '/misc/helpers.php';
$helpyHelperton = $cli->getHelp();

$helpyHelperton
	->setScriptName('cmux-bak')
	->setDescription('Backup and restore cmux workspace/session state.')
	->setSampleUsage('[audit] [--restore] [--file=<path>] [--dry-run] [--verbose]')
	->buildDocs([
		'audit'          => 'Report which backed-up Claude sessions are not running now, then offer to resume them',
		'--restore'      => 'Restore from backup, auditing existing workspaces first',
		'--file=<path>'  => 'Backup file path (default: ~/.config/cmux/bak.json)',
		'--dry-run'      => 'Show what would be done without making changes',
		'--verbose'      => 'Show detailed progress',
	]);

if ($helpyHelperton->batSignal) {
	$cli->msg($helpyHelperton->getHelp());
	exit(0);
}

require_once dirname(__DIR__) . '/misc/helpers/cmux.php';
require_once __DIR__ . '/cmux-bak_lib.php';

try {
	$cmd = new CmuxBak($cli);
	$cmd->run();
} catch (\Exception $e) {
	$cli->err($e->getMessage());
	exit(1);
}

exit(0);
