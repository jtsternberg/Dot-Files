#!/usr/bin/env php
<?php
namespace JT;
# =============================================================================
# Switch Ollama models storage location (local vs portable SD).
# By Justin Sternberg <me@jtsternberg.com>
#
# Version 0.2.0
#
# Updates the ~/.ollama-models symlink (where we point Ollama via
# OLLAMA_MODELS, set automatically by this script via `launchctl setenv`)
# to point at either local storage (~/.ollama-local-models) or the portable
# drive (/Volumes/AI-LAB/ollama/models). Removes any existing symlink first.
#
# The `reconcile` subcommand symlinks local-primary models (manifests +
# blobs) into the SD tree so the SD store can "see" all models. Direction is
# always local → SD; never the reverse (would dangle when SD ejects).
#
# WARNING: Do NOT run `ollama rm <model>` while on SD after reconcile — it
# may follow the symlinks and delete the local originals (6+ GB re-download).
# This is unverified. If you need to remove a symlinked model, do it while on
# local (`ollamodels local && ollama rm <model>`).
#
# Usage:
# ollamodels [local|sd|auto|reconcile|installwatcher|removewatcher]
#
# Examples:
# ollamodels           # Auto: use SD if mounted, else local
# ollamodels auto      # Same as above
# ollamodels sd        # Switch to portable drive
# ollamodels local     # Switch to local ~/.ollama-local-models
# ollamodels reconcile --dry-run   # Preview local → SD symlink plan
# ollamodels reconcile -y          # Symlink local models into SD, no prompt
#
# A macOS LaunchAgent can watch /Volumes and auto-switch whenever the
# AI-LAB drive is mounted or ejected:
# ollamodels installwatcher   # Install and load the LaunchAgent
# ollamodels removewatcher    # Unload and remove the LaunchAgent
# =============================================================================

$cli = require_once dirname(__DIR__) . '/misc/helpers.php';
$helpyHelperton = $cli->getHelp();

$helpyHelperton
	->setScriptName('ollamodels')
	->setDescription('Switch Ollama models storage between local and portable SD drive. Also sets OLLAMA_MODELS in the launchd environment so Ollama.app picks up the symlink on next launch.')
	->setSampleUsage('[local|sd|auto|reconcile]')
	->buildDocs([
		'[local]'         => 'Use local storage (~/.ollama-local-models)',
		'[sd]'            => 'Use portable drive (/Volumes/AI-LAB/ollama/models)',
		'[auto]'          => 'Use SD if mounted, otherwise local (default when no arg)',
		'[reconcile]'     => 'Symlink local-primary models into the SD tree (local → SD) so both stores see all models. WARNING: after reconcile, only run `ollama rm` while on local — `ollama rm` on SD may follow symlinks and delete local originals (unverified).',
		'--dry-run'       => 'reconcile: print what would be symlinked without touching anything',
		'-y, --yes'       => 'reconcile: skip the confirmation prompt',
		'[installwatcher]'=> 'Install macOS LaunchAgent to auto-switch on mount/eject',
		'[removewatcher]' => 'Remove the LaunchAgent',
	]);

if ($helpyHelperton->batSignal) {
	$cli->msg($helpyHelperton->getHelp());
	exit(0);
}

$home = getenv('HOME') ?: $cli->convertPathToAbsolute('~');
$symlink = $home . '/.ollama-models';
$localPath = $home . '/.ollama-local-models';
$sdPath = '/Volumes/AI-LAB/ollama/models';

$sub = $cli->getArg(1);
if ($sub === '' || $sub === null) {
	$sub = 'auto';
}

// Detects a directory that holds only interrupted Ollama pull artifacts:
// blobs/ contains exclusively *-partial* files (no committed sha256 blobs),
// and manifests/ has no model files. Safe to delete — nothing was finalized.
function isOrphanedPartialDownloadDir(string $path): bool {
	if (!is_dir($path) || is_link($path)) {
		return false;
	}

	$entries = @scandir($path) ?: [];
	foreach ($entries as $entry) {
		if ($entry === '.' || $entry === '..' || $entry === '.DS_Store') {
			continue;
		}
		if ($entry !== 'blobs' && $entry !== 'manifests') {
			return false;
		}
	}

	$blobsDir = $path . '/blobs';
	if (is_dir($blobsDir)) {
		$hasAnyBlob = false;
		foreach (scandir($blobsDir) as $entry) {
			if ($entry === '.' || $entry === '..' || $entry === '.DS_Store') {
				continue;
			}
			$hasAnyBlob = true;
			if (strpos($entry, '-partial') === false) {
				return false;
			}
		}
		if (!$hasAnyBlob) {
			return false;
		}
	} else {
		return false;
	}

	$manifestsDir = $path . '/manifests';
	if (is_dir($manifestsDir)) {
		$iter = new \RecursiveIteratorIterator(
			new \RecursiveDirectoryIterator($manifestsDir, \FilesystemIterator::SKIP_DOTS)
		);
		foreach ($iter as $file) {
			if ($file->isFile() && $file->getFilename() !== '.DS_Store') {
				return false;
			}
		}
	}

	return true;
}

function removeDirRecursive(string $path): bool {
	if (is_link($path) || !is_dir($path)) {
		return @unlink($path);
	}
	$iter = new \RecursiveIteratorIterator(
		new \RecursiveDirectoryIterator($path, \FilesystemIterator::SKIP_DOTS),
		\RecursiveIteratorIterator::CHILD_FIRST
	);
	foreach ($iter as $item) {
		$ok = $item->isDir() && !$item->isLink() ? @rmdir($item->getPathname()) : @unlink($item->getPathname());
		if (!$ok) {
			return false;
		}
	}
	return @rmdir($path);
}

function switchTo(\JT\CLI\Helpers $cli, string $symlink, string $target, string $label): bool {
	if (!is_dir($target)) {
		$cli->err("Target not found or not a directory: {$target}");
		return false;
	}

	if (is_link($symlink)) {
		@unlink($symlink);
	} elseif (file_exists($symlink)) {
		if (isOrphanedPartialDownloadDir($symlink)) {
			$cli->msg("{$symlink} contains only interrupted Ollama download artifacts.", 'yellow');
			if ($cli->isAutoconfirm() || $cli->confirm("Remove it and continue?")) {
				if (!removeDirRecursive($symlink)) {
					$cli->exitErr("Failed to remove {$symlink}");
				}
				$cli->msg("Removed orphaned directory.", 'green');
			} else {
				$cli->exitErr("{$symlink} exists and is not a symlink. Remove or rename it first.");
			}
		} else {
			$cli->exitErr("{$symlink} exists and is not a symlink. Remove or rename it first.");
		}
	}

	if (!@symlink($target, $symlink)) {
		$cli->exitErr("Failed to create symlink: {$symlink} -> {$target}");
	}

	$cli->successMsg("Ollama models → {$label}: {$target}");

	// Bootstrap OLLAMA_MODELS in launchd so Ollama.app (launched by launchd)
	// inherits it on next start. Failure here doesn't undo the symlink.
	exec('launchctl setenv OLLAMA_MODELS ' . escapeshellarg($symlink) . ' 2>&1', $setenvOut, $setenvRet);
	if ($setenvRet !== 0) {
		$cli->msg('Warning: launchctl setenv OLLAMA_MODELS failed: ' . implode("\n", $setenvOut), 'yellow');
	} elseif (!$cli->isSilent()) {
		$cli->msg("Set launchd OLLAMA_MODELS={$symlink}", 'cyan');
	}

	// If Ollama.app is currently running, the setenv only affects new launches.
	exec('pgrep -x Ollama 2>/dev/null', $pgrepOut, $pgrepRet);
	if ($pgrepRet === 0 && !empty($pgrepOut)) {
		$cli->msg('Note: Ollama.app is running — quit and relaunch it for OLLAMA_MODELS to take effect.', 'yellow');
	}

	return true;
}

/**
 * Symlink local-primary models (manifests + blobs) into the SD tree so the
 * SD store sees all models. Direction is strictly local → SD.
 */
function reconcile(\JT\CLI\Helpers $cli, string $localPath, string $sdPath): bool {
	if (!is_dir($sdPath) || !is_readable($sdPath)) {
		$cli->err("SD drive not mounted ({$sdPath}). Mount it, then re-run `ollamodels reconcile`.");
		return false;
	}

	$dryRun = $cli->hasFlag('dry-run');

	$cli->msg('WARNING: Do NOT run `ollama rm <model>` while on SD after reconcile — it may', 'yellow');
	$cli->msg('follow the symlinks and delete the local originals (6+ GB re-download).', 'yellow');
	$cli->msg('This is unverified. If you need to remove a symlinked model, do it while on', 'yellow');
	$cli->msg('local (`ollamodels local && ollama rm <model>`).', 'yellow');
	echo "\n";

	$libDir = $localPath . '/manifests/registry.ollama.ai/library';
	if (!is_dir($libDir)) {
		$cli->err("No local manifests found at {$libDir}");
		return false;
	}

	// Build the plan: per model tag, which manifests/blobs need symlinks.
	$plan = [];
	$iter = new \RecursiveIteratorIterator(
		new \RecursiveDirectoryIterator($libDir, \FilesystemIterator::SKIP_DOTS)
	);
	foreach ($iter as $file) {
		if (!$file->isFile() || $file->getFilename() === '.DS_Store') {
			continue;
		}
		$manifestPath = $file->getPathname();
		$rel = substr($manifestPath, strlen($localPath) + 1); // manifests/registry.../library/<model>/<tag>
		$tag = basename(dirname($manifestPath)) . ':' . $file->getFilename();
		$sdManifest = $sdPath . '/' . $rel;

		$entry = ['manifest' => null, 'blobs' => [], 'shared' => 0, 'already' => 0];

		if (is_link($sdManifest)) {
			$entry['already']++;
		} elseif (file_exists($sdManifest)) {
			continue; // SD has its own real copy of this model — don't touch it
		} else {
			$entry['manifest'] = ['from' => $manifestPath, 'to' => $sdManifest];
		}

		$json = json_decode((string) file_get_contents($manifestPath), true);
		if (!is_array($json)) {
			$cli->msg("Skipping {$tag}: could not parse manifest JSON ({$manifestPath})", 'yellow');
			continue;
		}
		$digests = [];
		if (!empty($json['config']['digest'])) {
			$digests[] = $json['config']['digest'];
		}
		foreach ($json['layers'] ?? [] as $layer) {
			if (!empty($layer['digest'])) {
				$digests[] = $layer['digest'];
			}
		}
		foreach (array_unique($digests) as $digest) {
			$blobName = str_replace(':', '-', $digest); // sha256:<hash> → sha256-<hash>
			$localBlob = $localPath . '/blobs/' . $blobName;
			$sdBlob = $sdPath . '/blobs/' . $blobName;
			if (is_link($sdBlob)) {
				$entry['already']++;
			} elseif (file_exists($sdBlob)) {
				$entry['shared']++; // real file on SD (shared layer) — leave it
			} elseif (file_exists($localBlob)) {
				$entry['blobs'][] = ['from' => $localBlob, 'to' => $sdBlob];
			} else {
				$cli->msg("Skipping blob for {$tag}: missing locally ({$blobName})", 'yellow');
			}
		}

		if ($entry['manifest'] || $entry['blobs']) {
			$plan[$tag] = $entry;
		}
	}

	if (!$plan) {
		$cli->successMsg('Nothing to reconcile — SD already sees all local models.');
		return true;
	}

	// Print the plan
	$totalLinks = 0;
	foreach ($plan as $tag => $entry) {
		$manifests = $entry['manifest'] ? 1 : 0;
		$blobs = count($entry['blobs']);
		$totalLinks += $manifests + $blobs;
		$cli->msg("{$tag}", 'cyan');
		$cli->msg("  manifests to symlink: {$manifests}, blobs to symlink: {$blobs}, blobs shared on SD: {$entry['shared']}", 'cyan');
	}
	$cli->msg("Total symlinks to create: {$totalLinks}", 'white');

	if ($dryRun) {
		echo "\n";
		foreach ($plan as $entry) {
			$links = $entry['blobs'];
			if ($entry['manifest']) {
				array_unshift($links, $entry['manifest']);
			}
			foreach ($links as $link) {
				$cli->msg("would link: {$link['to']} -> {$link['from']}", 'yellow');
			}
		}
		$cli->msg('Dry run — nothing created.', 'yellow');
		return true;
	}

	if (!$cli->isAutoconfirm() && !$cli->confirm('Create these symlinks (local → SD)?')) {
		$cli->msg('Aborted.', 'yellow');
		return false;
	}

	$created = 0;
	$failed = 0;
	foreach ($plan as $tag => $entry) {
		$links = $entry['blobs'];
		if ($entry['manifest']) {
			array_unshift($links, $entry['manifest']);
		}
		$linked = 0;
		foreach ($links as $link) {
			$dir = dirname($link['to']);
			if (!is_dir($dir) && !@mkdir($dir, 0755, true)) {
				$cli->err("Failed to create directory {$dir}");
				$failed++;
				continue;
			}
			if (@symlink($link['from'], $link['to'])) {
				$created++;
				$linked++;
			} else {
				$cli->err("Failed to symlink {$link['to']}");
				$failed++;
			}
		}
		$cli->successMsg("{$tag}: {$linked} symlink(s) created ({$entry['shared']} blob(s) already shared on SD)");
		promoteLocationToBoth($cli, $tag);
	}

	echo "\n";
	$cli->successMsg("Reconcile complete: {$created} symlink(s) created" . ($failed ? ", {$failed} FAILED" : ''));
	$cli->msg('Reminder: run `ollama rm` only while on local for these models (see warning above).', 'yellow');
	return $failed === 0;
}

/**
 * If ~/.ollama-why.json has a note for this model tagged location "local",
 * promote it to "both". Silent no-op otherwise.
 */
function promoteLocationToBoth(\JT\CLI\Helpers $cli, string $tag): void {
	$file = getenv('HOME') . '/.ollama-why.json';
	if (!file_exists($file)) {
		return;
	}
	$data = json_decode((string) file_get_contents($file), true);
	if (!is_array($data) || !isset($data['models']) || !is_array($data['models'])) {
		return; // old/unknown shape — leave it to ollama-why
	}
	if (($data['models'][$tag]['location'] ?? '') !== 'local') {
		return;
	}
	$data['models'][$tag]['location'] = 'both';
	$out = [
		'models'    => (object) $data['models'],
		'graveyard' => (object) ($data['graveyard'] ?? []),
	];
	file_put_contents($file, json_encode($out, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n");
	$cli->msg("  ollama-why: {$tag} location promoted local → both", 'cyan');
}

$ok = true;
switch (strtolower($sub)) {
	case 'reconcile':
		$ok = reconcile($cli, $localPath, $sdPath);
		break;
	case 'local':
		$ok = switchTo($cli, $symlink, $localPath, 'local');
		break;
	case 'sd':
		$ok = switchTo($cli, $symlink, $sdPath, 'SD');
		break;
	case 'auto':
		if (is_dir($sdPath) && is_readable($sdPath)) {
			$ok = switchTo($cli, $symlink, $sdPath, 'SD (auto)');
		} else {
			if (!$cli->isSilent()) {
				$cli->msg('SD not mounted, using local.', 'yellow');
			}
			$ok = switchTo($cli, $symlink, $localPath, 'local (auto)');
		}
		break;
	case 'installwatcher':
		$plistLabel = 'com.jt.ollamodels-watcher';
		$plistDir   = $home . '/Library/LaunchAgents';
		$plistPath  = $plistDir . '/' . $plistLabel . '.plist';
		$scriptPath = realpath(__FILE__);

		if (file_exists($plistPath)) {
			$cli->msg('LaunchAgent already installed at ' . $plistPath, 'yellow');
			$cli->msg('Run "ollamodels removewatcher" first to reinstall.');
			exit(0);
		}

		$phpBin = PHP_BINARY;

		$plistXml = <<<XML
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>{$plistLabel}</string>
	<key>WatchPaths</key>
	<array>
		<string>/Volumes</string>
	</array>
	<key>ProgramArguments</key>
	<array>
		<string>{$phpBin}</string>
		<string>{$scriptPath}</string>
		<string>auto</string>
		<string>--silent</string>
	</array>
</dict>
</plist>
XML;

		if (!is_dir($plistDir)) {
			@mkdir($plistDir, 0755, true);
		}

		if (!file_put_contents($plistPath, $plistXml)) {
			$cli->exitErr("Failed to write {$plistPath}");
		}

		exec('launchctl load ' . escapeshellarg($plistPath) . ' 2>&1', $out, $ret);
		if ($ret !== 0) {
			$cli->exitErr('launchctl load failed: ' . implode("\n", $out));
		}

		$cli->successMsg("LaunchAgent installed and loaded.");
		$cli->msg("Ollama models will auto-switch when drives are mounted/ejected.");
		break;

	case 'removewatcher':
		$plistLabel = 'com.jt.ollamodels-watcher';
		$plistPath  = $home . '/Library/LaunchAgents/' . $plistLabel . '.plist';

		if (!file_exists($plistPath)) {
			$cli->msg('LaunchAgent not installed.', 'yellow');
			exit(0);
		}

		exec('launchctl unload ' . escapeshellarg($plistPath) . ' 2>&1', $out, $ret);
		@unlink($plistPath);

		$cli->successMsg("LaunchAgent removed.");
		break;

	default:
		$cli->err("Unknown target: {$sub}");
		$cli->msg($helpyHelperton->getHelp());
		exit(1);
}

exit($ok ? 0 : 1);
