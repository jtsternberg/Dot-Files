#!/usr/bin/env php
<?php
namespace JT;
# =============================================================================
# Annotate `ollama list` with notes about when/why/how to use each model.
# By Justin Sternberg <me@jtsternberg.com>
#
# Version 0.3.0
#
# Shows `ollama list` with a column of your own notes about when to use each
# model. Notes live in ~/.ollama-why.json so they sync with your dotfiles if
# you symlink that file.
#
# Also keeps a "graveyard" of models that were tested and removed, so future
# sessions don't re-benchmark a model that was already tried and killed.
#
# Location-aware: notes can record which drive a model lives on (local, sd,
# or both — see `ollamodels`). When the SD drive is unmounted, sd-tagged
# models show as "Offline" instead of "Orphaned".
#
# Examples:
# ollama-why                                              # show annotated list
# ollama-why set qwen3-coder:latest "Primary coding agent"
# ollama-why set gemma4:26b-nvfp4 --when="General chat" --speed="MoE, 4B active"
# ollama-why set qwen2.5-coder:1.5b --tested="Cron title generator, 152 tok/s stable"
# ollama-why rm llama3.1:8b                               # remove a note
# ollama-why rm gemma4:31b --delete-model --tested="Too slow; pi 0/4"
#                                                         # archive note to graveyard AND run `ollama rm`
# ollama-why set qwen3-coder:latest --location=sd         # tag which drive it lives on
# ollama-why locate gemma4:26b-nvfp4 both                 # shorthand for --location
# ollama-why history                                      # show the graveyard
# ollama-why forget gemma4:31b                            # permanently delete a graveyard entry
# ollama-why notes                                        # show raw notes JSON
#
# Usage (`ollama-why -h`):
# ollama-why [<command>] [<model>] [<note>] [--when=<text>] [--speed=<text>] [--tags=<csv>] [--tested=<text>] [--location=<local|sd|both>]
# =============================================================================

$cli = require_once dirname(__DIR__) . '/src/bootstrap.php';

$helpyHelperton = $cli->getHelp();

$helpyHelperton
	->setScriptName('ollama-why')
	->setDescription('Annotate `ollama list` with your own notes about when to use each model')
	->setSampleUsage('[set|rm|locate|history|forget|notes|path] [<model>] [<when-text>] [--when=<text>] [--speed=<text>] [--tags=<csv>] [--tested=<text>] [--location=<local|sd|both>]')
	->buildDocs([
		'(no command)'     => 'Show `ollama list` with a WHEN column populated from your notes',
		'set <model> ...'  => 'Add or update a note. Positional: `ollama-why set <model> "quick when-text"`',
		'rm <model>'       => 'Remove a note (with --delete-model: archive the note to the graveyard and `ollama rm` the model)',
		'locate <model> <location>' => 'Set which drive a model lives on (shorthand for `set <model> --location=<value>`)',
		'history'          => 'Show the graveyard: models previously tested & removed',
		'forget <model>'   => 'Permanently delete a graveyard entry',
		'notes'            => 'Print raw notes JSON (for editing / piping)',
		'path'             => 'Print the path to the notes file (~/.ollama-why.json)',
		'--when=<text>'    => 'When/why to use this model',
		'--speed=<text>'   => 'Speed note (e.g. "~120 tok/s MLX", "MoE 3B active")',
		'--tags=<csv>'     => 'Comma-separated tags (e.g. "coding,agent,mlx")',
		'--tested=<text>'  => 'Test result summary (on `set`, or included in the graveyard entry on `rm --delete-model`)',
		'--location=<val>' => 'Which drive the model lives on: local, sd, or both (--loc works too; auto-detected on `set` for installed models)',
	]);

if ($helpyHelperton->batSignal) {
	$cli->msg($helpyHelperton->getHelp($cli->getArg(1)));
	exit(0);
}

define('JT\\OLLAMA_WHY_FILE', $_SERVER['HOME'] . '/.ollama-why.json');
define('JT\\OLLAMA_SD_PATH', '/Volumes/AI-LAB/ollama/models');
define('JT\\OLLAMA_STORE_LINK', $_SERVER['HOME'] . '/.ollama-models');
const LOCATIONS = ['local', 'sd', 'both'];

$cmd = $cli->getArg(1);

switch ($cmd) {
	case 'set':     cmd_set($cli); break;
	case 'rm':      cmd_rm($cli); break;
	case 'locate':  cmd_locate($cli); break;
	case 'history': cmd_history($cli); break;
	case 'forget':  cmd_forget($cli); break;
	case 'notes':   cmd_notes($cli); break;
	case 'path':    echo OLLAMA_WHY_FILE . "\n"; break;
	case null:
	case '':        cmd_list($cli); break;
	default:
		$cli->exitErr("Unknown command: {$cmd}. Run `ollama-why -h`.", 1);
}

/**
 * Load the data file, transparently migrating the old flat shape
 * (models as top-level keys) to the new { models, graveyard } shape.
 */
function load_data(): array {
	$data = ['models' => [], 'graveyard' => []];
	if (!file_exists(OLLAMA_WHY_FILE)) {
		return $data;
	}
	$raw = json_decode(file_get_contents(OLLAMA_WHY_FILE), true);
	if (!is_array($raw)) {
		return $data;
	}
	if (isset($raw['models']) || isset($raw['graveyard'])) {
		$data['models']    = is_array($raw['models'] ?? null) ? $raw['models'] : [];
		$data['graveyard'] = is_array($raw['graveyard'] ?? null) ? $raw['graveyard'] : [];
	} else {
		// Old flat shape: everything top-level is a model note.
		$data['models'] = $raw;
	}
	return $data;
}

function save_data(array $data): void {
	ksort($data['models']);
	ksort($data['graveyard']);
	// Cast to objects so empty maps encode as {} rather than []
	$out = [
		'models'    => (object) $data['models'],
		'graveyard' => (object) $data['graveyard'],
	];
	file_put_contents(
		OLLAMA_WHY_FILE,
		json_encode($out, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n"
	);
}

function sd_mounted(): bool {
	return is_dir(OLLAMA_SD_PATH) && is_readable(OLLAMA_SD_PATH);
}

/**
 * Which store the ~/.ollama-models symlink currently points at.
 *
 * @return string|null 'sd', 'local', or null if the link is missing/unrecognized.
 */
function active_store(): ?string {
	if (!is_link(OLLAMA_STORE_LINK)) {
		return null;
	}
	$target = readlink(OLLAMA_STORE_LINK);
	if ($target === OLLAMA_SD_PATH) {
		return 'sd';
	}
	if ($target === $_SERVER['HOME'] . '/.ollama-local-models') {
		return 'local';
	}
	return null;
}

/**
 * Read the --location/--loc flag, validating against LOCATIONS.
 *
 * @return string|null Validated location, or null when the flag wasn't passed.
 */
function get_location_flag($cli): ?string {
	$loc = $cli->getFlag('location');
	if ($loc === null || $loc === false) {
		$loc = $cli->getFlag('loc');
	}
	if ($loc === null || $loc === false) {
		return null;
	}
	$loc = strtolower(trim($loc));
	if (!in_array($loc, LOCATIONS, true)) {
		$cli->exitErr("Invalid --location \"{$loc}\". Use one of: " . implode(', ', LOCATIONS), 1);
	}
	return $loc;
}

function location_badge($cli, ?string $location, bool $pad = false): string {
	$colors = ['local' => 'cyan', 'sd' => 'magenta', 'both' => 'green'];
	$label = '[' . ($location ?: '?') . ']';
	if ($pad) {
		$label = str_pad($label, 7); // widest is [local]
	}
	$color = $colors[$location] ?? 'dark_gray';
	return $cli->color($color) . $label . $cli->color('none');
}

function term_width(): int {
	static $width = null;
	if ($width !== null) {
		return $width;
	}
	// stty against the controlling tty — `tput cols` sees no tty from PHP and lies (80)
	$size = trim((string) shell_exec('stty size < /dev/tty 2>/dev/null'));
	$cols = 0;
	if (preg_match('/^\d+\s+(\d+)$/', $size, $m)) {
		$cols = (int) $m[1];
	}
	if (!$cols) {
		$cols = (int) getenv('COLUMNS');
	}
	return $width = ($cols > 40 ? $cols : 120);
}

/**
 * Word-wrap text to fit the terminal, indenting continuation lines
 * so they stay aligned under the starting column.
 */
function wrap_text(string $text, int $start_col): string {
	$avail = max(30, term_width() - $start_col - 2);
	$wrapped = wordwrap($text, $avail, "\n", false);
	return str_replace("\n", "\n" . str_repeat(' ', $start_col), $wrapped);
}

function cmd_set($cli): void {
	$model = $cli->getArg(2);
	if (!$model) {
		$cli->exitErr('Missing <model>. Usage: ollama-why set <model> [<when-text>] [--when=<text>] [--speed=<text>] [--tags=<csv>] [--tested=<text>]', 1);
	}
	$data = load_data();
	$entry = $data['models'][$model] ?? [];
	$had = (bool) $entry;

	// Positional shorthand: `ollama-why set foo "Primary coder"` = --when="Primary coder"
	$positional = $cli->getArg(3);
	if ($positional && !$cli->hasFlag('when')) {
		$entry['when'] = $positional;
	}

	foreach (['when', 'speed', 'tested'] as $k) {
		$v = $cli->getFlag($k);
		if ($v !== null && $v !== false) {
			$entry[$k] = $v;
		}
	}
	$tags = $cli->getFlag('tags');
	if ($tags !== null && $tags !== false) {
		$entry['tags'] = array_map('trim', array_filter(explode(',', $tags)));
	}
	$location = get_location_flag($cli);
	if ($location !== null) {
		$entry['location'] = $location;
	} elseif (empty($entry['location'])) {
		// Auto-detect from the active store, but only for installed models.
		$store = active_store();
		if ($store && in_array($model, installed_models(), true)) {
			$entry['location'] = $store;
			$cli->msg("Auto-detected location: {$store} (override with --location=local|sd|both)", 'yellow');
		}
	}

	if (!$entry) {
		$cli->exitErr('Nothing to set. Provide a when-text or --when/--speed/--tags/--tested/--location.', 1);
	}

	if (!$had && isset($data['graveyard'][$model])) {
		$cli->msg("Note: {$model} is in the graveyard (removed {$data['graveyard'][$model]['removed_at']}). Creating a fresh active note; `ollama-why forget {$model}` to clear the graveyard entry.", 'yellow');
	}

	$data['models'][$model] = $entry;
	save_data($data);
	$cli->successMsg("Saved note for {$model}");
	foreach ($entry as $k => $v) {
		$val = is_array($v) ? implode(',', $v) : $v;
		$cli->msg("  {$k}: {$val}", 'cyan');
	}
}

function cmd_rm($cli): void {
	$model = $cli->getArg(2);
	if (!$model) {
		$cli->exitErr('Missing <model>. Usage: ollama-why rm <model> [--delete-model] [--tested=<text>]', 1);
	}
	$data = load_data();
	$had_note = isset($data['models'][$model]);
	$delete_model = $cli->hasFlag('delete-model');

	if ($had_note) {
		if ($delete_model) {
			// Archive to the graveyard instead of deleting.
			$entry = $data['models'][$model];
			$entry['removed_at'] = date('Y-m-d');
			$tested = $cli->getFlag('tested');
			if ($tested !== null && $tested !== false) {
				$entry['tested'] = $tested;
			}
			$data['graveyard'][$model] = $entry;
			unset($data['models'][$model]);
			save_data($data);
			$cli->successMsg("Archived note for {$model} to graveyard (removed_at: {$entry['removed_at']})");
		} else {
			unset($data['models'][$model]);
			save_data($data);
			$cli->successMsg("Removed note for {$model}");
		}
	} else {
		$cli->msg("No note found for {$model}", 'yellow');
		if ($delete_model) {
			// Still leave a tombstone so we know it was tried.
			$entry = ['removed_at' => date('Y-m-d')];
			$tested = $cli->getFlag('tested');
			if ($tested !== null && $tested !== false) {
				$entry['tested'] = $tested;
			}
			$data['graveyard'][$model] = $entry;
			save_data($data);
			$cli->msg("Added graveyard tombstone for {$model}", 'yellow');
		}
	}

	if ($delete_model) {
		$cli->msg("Running: ollama rm {$model}", 'cyan');
		$output = [];
		$code = 0;
		exec('ollama rm ' . escapeshellarg($model) . ' 2>&1', $output, $code);
		foreach ($output as $line) {
			echo $line . "\n";
		}
		if ($code === 0) {
			$cli->successMsg("Deleted model {$model}");
		} else {
			$cli->exitErr("`ollama rm` failed with exit code {$code}", $code);
		}
	} elseif (!$had_note) {
		// Nothing to do; no note and no --delete-model
		exit(1);
	}
}

function cmd_locate($cli): void {
	$model = $cli->getArg(2);
	$location = strtolower(trim((string) $cli->getArg(3)));
	if (!$model || !$location) {
		$cli->exitErr('Usage: ollama-why locate <model> <local|sd|both>', 1);
	}
	if (!in_array($location, LOCATIONS, true)) {
		$cli->exitErr("Invalid location \"{$location}\". Use one of: " . implode(', ', LOCATIONS), 1);
	}
	$data = load_data();
	$entry = $data['models'][$model] ?? [];
	$entry['location'] = $location;
	$data['models'][$model] = $entry;
	save_data($data);
	$cli->successMsg("Set location for {$model}: {$location}");
}

/**
 * Model names currently reported by `ollama list` (empty array on failure).
 */
function installed_models(): array {
	$output = [];
	$code = 0;
	exec('ollama list 2>/dev/null', $output, $code);
	if ($code !== 0) {
		return [];
	}
	array_shift($output); // header
	$models = [];
	foreach ($output as $line) {
		if (preg_match('/^(\S+)\s+/', $line, $m)) {
			$models[] = $m[1];
		}
	}
	return $models;
}

function cmd_history($cli): void {
	$data = load_data();
	if (!$data['graveyard']) {
		$cli->msg('Graveyard is empty — no models tested & removed yet.', 'yellow');
		return;
	}
	$cli->msg('Previously tested & removed:', 'white');
	foreach ($data['graveyard'] as $model => $entry) {
		$removed = $entry['removed_at'] ?? '?';
		$badge = !empty($entry['location']) ? ' ' . location_badge($cli, $entry['location']) : '';
		echo $cli->color('red') . '  ' . $model . $cli->color('none') . $badge
			. $cli->color('yellow') . '  (removed ' . $removed . ')' . $cli->color('none') . "\n";
		if (!empty($entry['tested'])) {
			$cli->msg('      tested: ' . $entry['tested'], 'cyan');
		}
		if (!empty($entry['when'])) {
			$cli->msg('      when: ' . $entry['when'], 'green');
		}
		if (!empty($entry['speed'])) {
			$cli->msg('      speed: ' . $entry['speed'], 'cyan');
		}
		if (!empty($entry['tags'])) {
			$cli->msg('      tags: ' . implode(', ', $entry['tags']), 'magenta');
		}
	}
}

function cmd_forget($cli): void {
	$model = $cli->getArg(2);
	if (!$model) {
		$cli->exitErr('Missing <model>. Usage: ollama-why forget <model>', 1);
	}
	$data = load_data();
	if (!isset($data['graveyard'][$model])) {
		$cli->exitErr("No graveyard entry for {$model}", 1);
	}
	unset($data['graveyard'][$model]);
	save_data($data);
	$cli->successMsg("Forgot graveyard entry for {$model}");
}

function cmd_notes($cli): void {
	echo file_exists(OLLAMA_WHY_FILE) ? file_get_contents(OLLAMA_WHY_FILE) : "{}\n";
}

function cmd_list($cli): void {
	$output = [];
	$code = 0;
	exec('ollama list 2>&1', $output, $code);
	if ($code !== 0) {
		$cli->exitErr("`ollama list` failed:\n" . implode("\n", $output), $code);
	}

	$data = load_data();
	$notes = $data['models'];
	$seen_models = [];
	$sd_up = sd_mounted();

	// SD-offline banner: any sd/both-tagged note while SD is unmounted
	if (!$sd_up) {
		$offline_count = count(array_filter($notes, function ($n) {
			return in_array($n['location'] ?? '', ['sd', 'both'], true);
		}));
		if ($offline_count) {
			$cli->msg("⚠️  SD drive (/Volumes/AI-LAB) not mounted — {$offline_count} model(s) tagged 'sd' are offline.", 'yellow');
			echo "\n";
		}
	}

	// Measure ollama's rows so the WHEN column lines up
	$rows = array_values(array_filter(array_map('rtrim', $output), 'strlen'));
	$header = rtrim(array_shift($output));
	$col = strlen($header);
	foreach ($rows as $row) {
		$col = max($col, strlen($row));
	}
	$col += 4;

	$cli->msg(str_pad($header, $col) . 'WHEN', 'white');

	foreach ($rows as $line) {
		if ($line === $header) continue;
		// Columns are space-separated; first col is NAME
		if (!preg_match('/^(\S+)\s+/', $line, $m)) {
			echo $line . "\n";
			continue;
		}
		$model = $m[1];
		$seen_models[$model] = true;
		$note = $notes[$model] ?? null;
		$padded = str_pad($line, $col);

		if ($note) {
			$when = $note['when'] ?? '';
			$badge = location_badge($cli, $note['location'] ?? null, true);
			echo $padded . $badge . ' ' . $cli->color('green') . $when . $cli->color('none') . "\n";
			$indent = str_repeat(' ', $col + 8); // badge width + space
			if (!empty($note['speed'])) {
				$cli->msg($indent . 'speed: ' . $note['speed'], 'cyan');
			}
			if (!empty($note['tested'])) {
				$cli->msg($indent . 'tested: ' . $note['tested'], 'cyan');
			}
			if (!empty($note['tags'])) {
				$cli->msg($indent . 'tags: ' . implode(', ', $note['tags']), 'magenta');
			}
		} else {
			echo $padded . $cli->color('yellow') . '(no note — run: ollama-why set ' . $model . ' "...")' . $cli->color('none') . "\n";
		}
	}

	// Split missing models into offline (on the unmounted SD) vs true orphans
	$missing = array_diff_key($notes, $seen_models);
	$orphans = [];
	$offline = [];
	foreach ($missing as $model => $note) {
		$loc = $note['location'] ?? null;
		if (!$sd_up && in_array($loc, ['sd', 'both'], true)) {
			$offline[$model] = $note;
		} else {
			$orphans[$model] = $note;
		}
	}

	$name_w = 0;
	foreach (array_merge(array_keys($missing), array_keys($data['graveyard'])) as $model) {
		$name_w = max($name_w, strlen($model));
	}
	$name_w += 2;

	if ($offline) {
		echo "\n";
		$cli->msg('Offline (SD unmounted):', 'yellow');
		foreach ($offline as $model => $note) {
			$when = wrap_text($note['when'] ?? '', $name_w + 10);
			echo '  ' . location_badge($cli, $note['location'], true) . ' '
				. $cli->color('magenta') . str_pad($model, $name_w) . $cli->color('none')
				. $cli->color('green') . $when . $cli->color('none') . "\n";
		}
		$cli->msg('Tip: mount the drive, then `ollamodels auto` to switch stores.', 'yellow');
	}

	if ($orphans) {
		echo "\n";
		$cli->msg('Orphaned notes (models no longer installed):', 'yellow');
		foreach ($orphans as $model => $note) {
			$when = wrap_text($note['when'] ?? '', $name_w + 2);
			$cli->msg('  ' . str_pad($model, $name_w) . $when, 'red');
		}
		$cli->msg('Tip: `ollama-why rm <model>` to clean up.', 'yellow');
	}

	// Graveyard summary at the very bottom — one line each; full text in `history`
	if ($data['graveyard']) {
		echo "\n";
		$cli->msg('Previously tested & removed (see `ollama-why history`):', 'yellow');
		foreach ($data['graveyard'] as $model => $entry) {
			$removed = $entry['removed_at'] ?? '?';
			$summary = wrap_text($entry['tested'] ?? ($entry['when'] ?? ''), $name_w + 14);
			echo '  ' . $cli->color('red') . str_pad($model, $name_w) . $cli->color('none')
				. $cli->color('dark_gray') . str_pad($removed, 12) . $cli->color('none')
				. $summary . "\n";
		}
	}
}
