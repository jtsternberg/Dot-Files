#!/usr/bin/env python3
# =============================================================================
# chordpdf-to-text
# By Justin Sternberg <me@jtsternberg.com>
#
# Version 1.0.0
#
# Convert a chord-chart PDF (e.g. CCLI SongSelect) to plain text, faithfully
# preserving chord-over-lyric positions.
#
# Chords are snapped to the lyric character beneath their PDF x-coordinate, so
# alignment survives without the page-width padding that `pdftotext -layout`
# injects. Kerning splits ("E"+"sus", "C"+"ash") are re-fused; chord-only rows
# (intros, turnarounds, instrumentals) render as clean single-spaced measures.
#
# Requires `pdftotext` (poppler). Output goes to stdout.
#
# Usage:
#   chordpdf-to-text <chart.pdf>            # print to stdout
#   chordpdf-to-text <chart.pdf> > out.txt  # redirect to a file
# =============================================================================
import re
import sys
import html
import shutil
import subprocess

CHORD = re.compile(r'^[A-G][#b]?(?:m|maj|min|sus|dim|aug|add)?\d?(?:sus\d?)?(?:/[A-G][#b]?)?$')
BARLINE = re.compile(r'^[|:]+$')
SECTION = re.compile(r'^(INTRO|VERSE|CHORUS|PRE-?CHORUS|BRIDGE|TURNAROUND|INSTRUMENTAL|'
                     r'OUTRO|TAG|ENDING|INTERLUDE|REFRAIN|CODA|VAMP|CHANNEL)(\s*\d+)?$', re.I)
WORD_RX = re.compile(r'<word xMin="([\d.]+)" yMin="([\d.]+)" '
                     r'xMax="([\d.]+)" yMax="([\d.]+)">(.*?)</word>')

# Kerning splits measure <=1pt between fragments; the smallest real space (small
# credit font) is ~2.3pt and chord-to-chord gaps are >=25pt, so an absolute
# 1.5pt cutoff fuses only true splits without touching real spacing.
SPLIT_GAP = 1.5


def die(msg, code=1):
    print(f"chordpdf-to-text: {msg}", file=sys.stderr)
    sys.exit(code)


def run_pdftotext(*opts):
    def go(pdf):
        if not shutil.which("pdftotext"):
            die("pdftotext not found. Install poppler "
                "(brew install poppler / apt install poppler-utils).")
        try:
            return subprocess.run(["pdftotext", *opts, pdf, "-"],
                                  capture_output=True, text=True, check=True).stdout
        except subprocess.CalledProcessError as e:
            die(f"pdftotext failed: {e.stderr.strip() or e}")
    return go


bbox_xml = run_pdftotext("-bbox")
raw_text = run_pdftotext()  # default reading-order extraction


def parse_words(xml):
    words, page = [], -1
    for line in xml.splitlines():
        if "<page" in line:
            page += 1
        m = WORD_RX.search(line)
        if m:
            x0, y0, x1, y1, t = m.groups()
            words.append((page, float(y0), float(x0), float(x1), html.unescape(t)))
    return words


def group_lines(words):
    """Group words into lines by (page, yMin); yMin resets per page."""
    words.sort(key=lambda w: (w[0], w[1], w[2]))
    lines, cur, cy, cp = [], [], None, None
    for w in words:
        if cur and w[0] == cp and abs(w[1] - cy) <= 4.0:
            cur.append(w)
        else:
            if cur:
                lines.append(cur)
            cur, cy, cp = [w], w[1], w[0]
    if cur:
        lines.append(cur)
    return lines


def merge_splits(ln):
    """Fuse kerning-split fragments ("E"+"sus", "C"+"ash", "w"+"w") into one token."""
    ln = sorted(ln, key=lambda w: w[2])
    out = [list(ln[0])]
    for w in ln[1:]:
        if (w[2] - out[-1][3]) < SPLIT_GAP:
            out[-1][3] = w[3]          # extend xMax
            out[-1][4] += w[4]         # concatenate text
        else:
            out.append(list(w))
    return [tuple(w) for w in out]


NC = re.compile(r'^N\.?C\.?$', re.I)  # "N.C." = no chord


def is_symbol(tok):
    # a chord, a barline, "N.C.", or a chord carrying a parenthetical
    # extension/bass like "C(4)" / "(C(4))".
    return bool(CHORD.match(tok) or BARLINE.match(tok) or NC.match(tok)
                or tok.startswith('(') or tok.endswith(')'))


def strip_annotations(toks):
    """Remove parenthetical annotation spans, e.g. "(To V2 / Pre-Ch. 2)", which
    may span several word tokens and otherwise defeat the all-symbols test."""
    core, skip = [], False
    for t in toks:
        if skip:
            skip = not t.endswith(')')
        elif t.startswith('(') and not t.endswith(')'):
            skip = True
        elif t.startswith('(') and t.endswith(')'):
            continue
        else:
            core.append(t)
    return core


def classify(ln):
    toks = [w[4] for w in ln]
    if SECTION.match(" ".join(toks).strip()):
        return "section"
    core = strip_annotations(toks)
    # a chord row: every non-annotation token is a chord/barline (or the row is
    # pure annotation, e.g. "(5.) (D) (To Outro)").
    if all(is_symbol(t) for t in core):
        return "chord"
    return "text"


# Max baseline gap (pt) for a chord row to sit "over" the next text row. Body
# line spacing is ~12-14pt; a larger gap (e.g. OUTRO measures above the footer)
# means the text is unrelated, so the chords render as standalone measures.
PAIR_DY = 20.0


def adjacent(chord_ln, text_ln):
    return (chord_ln[0][0] == text_ln[0][0]
            and 0 < (min(w[1] for w in text_ln) - min(w[1] for w in chord_ln)) <= PAIR_DY)


def median_advance(words):
    a = sorted((w[3] - w[2]) / len(w[4]) for w in words if len(w[4]) >= 2 and w[3] > w[2])
    return a[len(a) // 2] if a else 6.0


def render_text(ln):
    """Plain text, single-spaced (splits already merged). Returns (str, wordmap)."""
    ln = sorted(ln, key=lambda w: w[2])
    s, wmap = "", []
    for i, w in enumerate(ln):
        if i:
            s += " "
        wmap.append((w[2], w[3], len(s), len(w[4])))  # xMin, xMax, colStart, length
        s += w[4]
    return s.rstrip(), wmap


def col_for_x(x, wmap, adv):
    first, last = wmap[0], wmap[-1]
    if x <= first[0]:
        return max(0, first[2] + round((x - first[0]) / adv))
    for i, (x0, x1, c0, ln) in enumerate(wmap):
        if x0 <= x <= x1:
            frac = (x - x0) / max(x1 - x0, 1e-6)
            return c0 + min(ln, round(frac * ln))
        if i + 1 < len(wmap) and x1 < x < wmap[i + 1][0]:
            return min(c0 + ln + round((x - x1) / adv), wmap[i + 1][2] - 1)
    return last[2] + last[3] + round((x - last[1]) / adv)


def place(items):
    """Render (col, text) items left-to-right with >=1 space, never overwriting."""
    s = ""
    for col, txt in sorted(items, key=lambda it: it[0]):
        if col < len(s):
            col = len(s) + (1 if s and not s.endswith(" ") else 0)
        s += " " * (col - len(s)) + txt
    return s.rstrip()


# Some SongSelect exports encode the whole layout as a monospace grid of '.'
# characters inside single per-line text runs (no real spaces or per-word
# coords). >20 interior letter.letter dots reliably flags that encoding; real
# charts (real spaces) score in the low single digits.
DOTGRID = re.compile(r'[^\W_]\.[^\W_]')
DOTGRID_MIN = 20


def base_title(text):
    """Song title without the trailing '[Key]'/'[Arrangement]' bracket."""
    first = next((l for l in text.splitlines() if l.strip()), "")
    return re.sub(r'\s*\[.*$', '', first).strip()


def strip_furniture(text, title):
    """Drop page-break noise: bare page numbers and repeated running headers."""
    hdr = re.compile(rf'^{re.escape(title)}\s*-?\s*$') if title else None
    keep = [ln for ln in text.splitlines()
            if not re.fullmatch(r'\s*\d+\s*', ln) and not (hdr and hdr.match(ln))]
    return re.sub(r'\n{3,}', '\n\n', "\n".join(keep)).strip("\n") + "\n"


def render_dotgrid(raw):
    """Type-B: the '.' grid already is the monospace layout; '.' -> space."""
    out = []
    for ln in raw.splitlines():
        out.append(ln.replace('.', ' ').rstrip())
    return "\n".join(out)


def convert(pdf):
    raw = raw_text(pdf)
    if len(DOTGRID.findall(raw)) > DOTGRID_MIN:
        return strip_furniture(render_dotgrid(raw), base_title(raw))

    words = parse_words(bbox_xml(pdf))
    if not words:
        die("no text found in PDF (is it a scanned image?)")
    adv = median_advance(words)
    lines = [merge_splits(ln) for ln in group_lines(words)]

    out, i = [], 0
    while i < len(lines):
        ln = lines[i]
        kind = classify(ln)
        if kind == "section":
            if out and out[-1] != "":
                out.append("")
            out.append(render_text(ln)[0])
            i += 1
        elif (kind == "chord" and i + 1 < len(lines)
              and classify(lines[i + 1]) == "text" and adjacent(ln, lines[i + 1])):
            lyric, wmap = render_text(lines[i + 1])
            chords = sorted(ln, key=lambda w: w[2])
            out.append(place([(col_for_x(w[2], wmap, adv), w[4]) for w in chords]))
            out.append(lyric)
            i += 2
        elif kind == "chord":
            # chord-only row (no lyric to anchor to): even single-spaced measures
            out.append(" ".join(w[4] for w in sorted(ln, key=lambda w: w[2])))
            i += 1
        else:
            out.append(render_text(ln)[0])
            i += 1

    return strip_furniture("\n".join(out), base_title(raw))


USAGE = """chordpdf-to-text — chord-chart PDF to plain text, preserving chord positions

Usage:
  chordpdf-to-text <chart.pdf>            print to stdout
  chordpdf-to-text <chart.pdf> > out.txt  redirect to a file

Requires pdftotext (poppler)."""


def main(argv):
    if any(a in ("-h", "--help") for a in argv[1:]):
        print(USAGE)
        sys.exit(0)
    if len(argv) != 2:
        print(USAGE, file=sys.stderr)
        sys.exit(1)
    sys.stdout.write(convert(argv[1]))


if __name__ == "__main__":
    main(sys.argv)
