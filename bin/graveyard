#!/usr/bin/env php
<?php
namespace JT;
# =============================================================================
# graveyard — demote, browse, and resurrect Claude Code sessions via cmux.
# By Justin Sternberg <me@jtsternberg.com>
#
# Version 0.1.0
#
# Buries idle Claude sessions to ~/.claude-graveyard/ (rendered transcript +
# metadata) and frees their RAM, then lists / opens / resurrects them.
#
# Usage:
# graveyard bury  (no args: interactive picker — fzf if available, else numbered REPL)
# graveyard bury <identifier> [--force] [-y]
#   identifier: cmux surface ref (surface:N), surface UUID, session-id (or
#   prefix), or a workspace/tab title substring. Ambiguous matches are
#   rejected (no auto-pick) — narrow it or pass a full session-id.
# graveyard bury <session-id> <session-id> [<session-id>...] [-y]
# graveyard bury --idle=<dur> [-y]  (space form "--idle <dur>" also works)
# graveyard candidates [--porcelain]
# graveyard peek <id> [--turns=N]   (preview a live session's recent turns; default 6)
# graveyard ls
# graveyard search <term> [--full-text] [--json]  (search buried sessions)
# graveyard page [--no-open]   (self-contained HTML overview of all buried sessions)
# graveyard show <id>
# graveyard resurrect <id|name> [--from-transcript]   (name = workspace/tab title substring; unique match required)
# =============================================================================

$cli = require_once dirname(__DIR__) . '/misc/helpers.php';
require_once dirname(__DIR__) . '/misc/helpers/cmux.php';
require_once __DIR__ . '/graveyard_lib.php';

$helpyHelperton = $cli->getHelp();
$helpyHelperton
	->setScriptName('graveyard')
	->setDescription('Demote, browse, and resurrect Claude Code sessions via cmux.')
	->setSampleUsage('<bury|ls|show|resurrect> [args]')
	->buildDocs([
		'bury' => 'No args: interactive picker over live candidates (fzf --multi with a read-screen preview if fzf is on PATH, else a numbered REPL), then bury the selection',
		'bury <identifier>' => 'Bury a single live session, resolved (in order) by exact cmux surface ref, exact surface UUID, session-id exact-or-prefix, or a workspace/tab title substring (case-insensitive). Ambiguous matches are rejected — narrow it or pass a full session-id.',
		'bury <id> <id> [<id>...]' => 'Bury multiple live sessions by session-id (TOCTOU-safe re-resolve before each)',
		'bury --idle=<d>' => 'Bury all sessions idle longer than <d> (e.g. 2d, 48h, 90m; space form "--idle <d>" also works)',
		'bury --workspace <name|ref>' => 'Bury every targetable Claude session in a workspace as a group (shared group id + layout manifest); non-Claude surfaces are snapshotted and closed. Any untargetable Claude aborts the whole bury unless --force.',
		'--force'         => 'bury <ref>: bury even if the session looks busy. bury --workspace: also skip untargetable Claude members instead of aborting (they stay alive; the workspace is not fully closed).',
		'-y'              => 'Skip confirmations',
		'candidates [--porcelain] [--json]' => 'List live buryable sessions sorted by idle time (--porcelain: tab-separated; --json: structured rows — both agent-readable)',
		'peek <id>'       => 'Preview a LIVE session\'s recent genuine turns (from its JSONL, skipping synthetic/command noise) before deciding to bury — no export, no bury',
		'ls'              => 'List buried sessions (--json: structured {workspaces,sessions})',
		'search <term>'   => 'Search buried sessions on workspace/tab/cwd/summary (case-insensitive, newest-first). --full-text also greps rendered transcripts; --json emits structured rows',
		'page [--no-open]' => 'Regenerate the self-contained HTML overview of every buried session at ~/.claude-graveyard/page.html — a full-width field of headstones; clicking one opens the full card and loads its transcript JIT from page-data/ — and open it in your browser (--no-open: just write the files)',
		'show <id>'       => 'Open a buried transcript in your editor',
		'resurrect <id|name>' => 'Recreate the workspace and resume the live session via --resume if its JSONL still exists, else restart Claude on the exported transcript. <name> may be a workspace/tab title substring — a unique match is required (ambiguous matches are listed, not auto-picked)',
		'resurrect --workspace <group>' => 'Rebuild a buried workspace from its manifest (tab order + cwds/urls) and resurrect each member session into position (resume-first)',
		'--from-transcript'  => 'Force resurrect to re-read the exported transcript instead of --resume, even if the JSONL still exists',
	]);

if ($helpyHelperton->batSignal) {
	$cli->msg($helpyHelperton->getHelp());
	exit(0);
}

$cmux = new Helpers\Cmux($cli);
if (!$cmux->ping()) {
	$cli->exitErr('cmux is not reachable. Is cmux running?');
}

$gy  = new Graveyard($cli, $cmux);
$sub = $cli->getArg(1);

switch ($sub) {
	case 'bury':
		if ($cli->hasFlag('workspace')) {
			$ws = (string) $cli->getFlag('workspace');
			if ($ws === '') { $ws = (string) $cli->getArg(2); } // supports "--workspace <name>" (space form)
			if ($ws === '') { $cli->exitErr('Usage: graveyard bury --workspace <name|ref>'); }
			$gy->buryWorkspace($ws, $cli->hasFlag('force'), $cli->isAutoconfirm());
		} elseif ($cli->hasFlag('idle')) {
			$dur = (string) $cli->getFlag('idle');
			if ($dur === '') { $dur = (string) $cli->getArg(2); } // supports "--idle 15s" (space-separated)
			if ($dur === '') { $cli->exitErr('Usage: graveyard bury --idle <dur>  (e.g. --idle=2d)'); }
			try {
				$secs = $gy->parseDuration($dur);
			} catch (\InvalidArgumentException $e) {
				$cli->exitErr("Invalid --idle duration: '{$dur}' (use e.g. 2d, 48h, 90m, 30s).");
			}
			$gy->buryIdle($secs, $cli->isAutoconfirm());
		} else {
			$rest = [];
			for ($i = 2; ($v = $cli->getArg($i)) !== null; $i++) { $rest[] = $v; }
			if (!$rest) { $gy->pickAndBury($cli->isAutoconfirm()); break; }
			if (count($rest) === 1) {
				$gy->buryByRef($rest[0], $cli->hasFlag('force'), $cli->isAutoconfirm());
			} else {
				$gy->buryIds($rest, $cli->isAutoconfirm());
			}
		}
		break;
	case 'candidates': $gy->printCandidates($cli->hasFlag('porcelain'), $cli->hasFlag('json')); break;
	case 'peek':
		$turns = $cli->hasFlag('turns') ? max(1, (int) $cli->getFlag('turns')) : 6;
		$gy->peekSession((string) $cli->getArg(2), $turns);
		break;
	case '_preview':   $gy->printPreview((string) $cli->getArg(2)); break;
	case 'ls':
		if ($cli->hasFlag('json')) { $gy->listTombstonesJson(); }
		else { $gy->listTombstones(); }
		break;
	case 'search':    $gy->printSearch((string) $cli->getArg(2), $cli->hasFlag('json'), $cli->hasFlag('full-text')); break;
	case 'page':      $gy->page(!$cli->hasFlag('no-open')); break;
	case 'show':      $gy->showTombstone((string) $cli->getArg(2)); break;
	case 'resurrect':
		if ($cli->hasFlag('workspace')) {
			$g = (string) $cli->getFlag('workspace');
			if ($g === '') { $g = (string) $cli->getArg(2); }
			if ($g === '') { $cli->exitErr('Usage: graveyard resurrect --workspace <group>'); }
			$gy->resurrectWorkspace($g, $cli->hasFlag('from-transcript'));
		} else {
			$gy->resurrect((string) $cli->getArg(2), $cli->hasFlag('from-transcript'));
		}
		break;
	default:
		$cli->msg($helpyHelperton->getHelp());
		exit($sub ? 1 : 0);
}

exit(0);
