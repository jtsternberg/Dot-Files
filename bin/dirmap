#!/usr/bin/env php
<?php
namespace JT;
# =============================================================================
# Utility for storing directory maps, making it easier to bookmark and navigate
# to directories on the drive.
# By Justin Sternberg <me@jtsternberg.com>
# https://github.com/jtsternberg/Dot-Files/blob/master/bin/dirmap
#
# Version 0.3.0
#
# Stores shortcuts for directories (a map) to a json file in the user dir.
#
# Usage:
# dirmap help
# dirmap add [<key>] [<path>]
# dirmap rename [<oldkey>] <newkey>
# dirmap remove <key>
# dirmap <key>
# dirmap get <key>
# dirmap identify [<path>]
# dirmap list [--json|-j]
# dirmap edit
# =============================================================================

class DirMap {

	protected $dirs = [
		'' => '~/',
	];

	protected $helpers;
	public $hd = '';
	public $source = '';
	public static $instance = null;

	public function __construct( CLI\Helpers $helpers ) {
		$this->helpers = $helpers;
		$this->hd = dirname( dirname( __DIR__ ) );
		$this->source = $this->hd . '/.dirmap.json';
		if ( ! file_exists( $this->source ) ) {
			file_put_contents( $this->hd . '/.dirmap.json', "{}\n" );
		}

		$this->dirs = json_decode( file_get_contents( $this->hd . '/.dirmap.json' ), true );
		$this->dirs[''] = '~/';
		self::$instance = $this;
	}

	public function get() {
		$key = $this->helpers->getArg( 1, '' );

		if ( ! empty( $key ) && ! isset( $this->dirs[ $key ] ) ) {
			$this->helpers->err( sprintf( "\nThere is no directory associated with the given key: '%s'", $key ), false );
			$this->helpers->msg( "Try `dirmap list` to see available keys\n" );

			exit( 1 );
		}

		if ( empty( $key ) ) {
			$key = '';
		}

		$dir = $this->dirs[ $key ];
		$dir = str_replace( '~', $this->hd, $dir );

		exit( $dir );
	}

	public function add( $args ) {
		array_shift( $args );
		array_shift( $args );
		$key = array_shift( $args );
		$path = implode( ' ', $args );

		if ( empty( $path ) || '.' === $path ) {
			$path = $this->helpers->wd;
		}

		// No key given: default to the name of the current directory.
		if ( empty( $key ) ) {
			$key = $this->helpers->currDir;
		}

		$dirs = $this->dirs;
		unset( $dirs[''] );
		$dirs[ $key ] = $path;
		$this->dirs[ $key ] = $path;

		$this->updateFile( $dirs );

		$this->helpers->msg( sprintf( "\nAdded: %s => %s\n", $key, $path ), 'green' );
	}

	public function remove( $args ) {
		if ( empty( $args[2] ) ) {
			$this->helpers->err( "\nThe directory map key (alias) is required." );
			$this->helpers->msg( "E.g. dirmap remove mysites\n" );
			exit(1);
		}

		array_shift( $args );
		array_shift( $args );
		$key = array_shift( $args );

		$dirs = $this->dirs;
		unset( $dirs[''] );
		unset( $dirs[ $key ] );
		unset( $this->dirs[ $key ] );

		$this->updateFile( $dirs );

		$this->helpers->msg( sprintf( "\nRemoved: %s\n", $key ), 'green' );
	}

	public function rename( $args ) {
		array_shift( $args );
		array_shift( $args );
		$first  = array_shift( $args );
		$second = array_shift( $args );

		// With a single arg, it's the new key: identify the current
		// directory to determine which existing key to rename.
		if ( empty( $second ) ) {
			$newKey = $first;
			$oldKey = $this->findKeyForPath( $this->helpers->wd );

			if ( empty( $oldKey ) ) {
				$this->helpers->err( sprintf( "\nNo dirmap key found for the current directory: '%s'", $this->helpers->wd ), false );
				$this->helpers->msg( "Provide the old key explicitly: dirmap rename <oldkey> <newkey>\n" );
				exit( 1 );
			}
		} else {
			$oldKey = $first;
			$newKey = $second;
		}

		if ( empty( $newKey ) ) {
			$this->helpers->err( "\nThe new directory map key (alias) is required." );
			$this->helpers->msg( "E.g. dirmap rename oldkey newkey\n" );
			exit( 1 );
		}

		if ( ! isset( $this->dirs[ $oldKey ] ) ) {
			$this->helpers->err( sprintf( "\nThere is no directory associated with the given key: '%s'", $oldKey ), false );
			$this->helpers->msg( "Try `dirmap list` to see available keys\n" );
			exit( 1 );
		}

		if ( $oldKey === $newKey ) {
			$this->helpers->err( sprintf( "\nThe new key is the same as the old key: '%s'\n", $oldKey ), false );
			exit( 1 );
		}

		if ( isset( $this->dirs[ $newKey ] ) ) {
			$this->helpers->err( sprintf( "\nA mapping already exists for the key: '%s' => %s", $newKey, $this->dirs[ $newKey ] ), false );
			$this->helpers->msg( "Remove it first, or choose a different key.\n" );
			exit( 1 );
		}

		$path = $this->dirs[ $oldKey ];

		$dirs = $this->dirs;
		unset( $dirs[''] );
		unset( $dirs[ $oldKey ] );
		$dirs[ $newKey ] = $path;

		unset( $this->dirs[ $oldKey ] );
		$this->dirs[ $newKey ] = $path;

		$this->updateFile( $dirs );

		$this->helpers->msg( sprintf( "\nRenamed: %s => %s (%s)\n", $oldKey, $newKey, $path ), 'green' );
	}

	public function identify( $args ) {
		array_shift( $args );
		array_shift( $args );
		$path = ! empty( $args ) ? implode( ' ', $args ) : $this->helpers->wd;

		if ( '.' === $path ) {
			$path = $this->helpers->wd;
		}

		$best = $this->findKeyForPath( $path );

		if ( empty( $best ) ) {
			$this->helpers->err( sprintf( "\nNo dirmap key found for: '%s'\n", $this->resolvePath( $path ) ), false );
			exit( 1 );
		}

		exit( $best );
	}

	protected function resolvePath( $path ) {
		$path = str_replace( '~', $this->hd, $path );
		$path = rtrim( $path, '/' );

		// Canonicalize symlinks (e.g. /tmp vs /private/tmp, or a symlinked
		// ~/Sites) so paths compare by their physical location. getcwd()
		// already returns the resolved path, so the stored side must match.
		// Falls back to the string path when it doesn't exist on disk.
		$real = realpath( $path );

		return false !== $real ? $real : $path;
	}

	protected function findKeyForPath( $path ) {
		$path = $this->resolvePath( $path );

		$best = '';
		foreach ( $this->dirs as $key => $dir ) {
			if ( '' === $key ) {
				continue;
			}

			if ( $this->resolvePath( $dir ) === $path ) {
				if ( empty( $best ) || strlen( $key ) < strlen( $best ) ) {
					$best = $key;
				}
			}
		}

		return $best;
	}

	public function edit() {
		$file   = $this->source;
		$hasVsc = '' !== trim( (string) shell_exec( 'command -v code 2>/dev/null' ) );
		if ( $hasVsc ) {
			// code -r: reuse the current window, return immediately (no hang).
			passthru( 'code -r ' . escapeshellarg( $file ) );
		} else {
			$editor = getenv( 'EDITOR' ) ?: 'vi';
			passthru( $editor . ' ' . escapeshellarg( $file ) );
		}
		$this->helpers->msg( sprintf( "\nOpened %s\n", $file ), 'green' );
	}

	public function list() {
		if ( $this->helpers->hasFlags( [ 'json' ], [ 'j' ] ) ) {
			exit( file_get_contents( $this->source ) );
		}

		if ( $this->helpers->hasFlags( [ 'keys' ], [ 'k' ] ) ) {
			exit( implode("\n", array_keys( $this->dirs ) ) );
		}

		$this->outputMap( $this->dirs, 'Current Map' );
	}

	protected function updateFile( $dirs ) {
		// Pretty-printed + unescaped slashes so the file is hand-editable
		// (see `dirmap edit`) and matches godo's ~/.godo-cmdmap.json format.
		// file_put_contents (not `echo '$json' >`) so paths containing a
		// single quote don't corrupt the write.
		$json = json_encode( $dirs, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES );
		file_put_contents( $this->hd . '/.dirmap.json', $json . "\n" );

		return $this;
	}

	protected function outputMap( $dirs, $msg = 'Directory map updated' ) {
		// Filter out the empty default key for display.
		$display = [];
		foreach ( $dirs as $key => $dir ) {
			if ( '' === $key ) {
				continue;
			}
			$display[ $key ] = $dir;
		}

		ksort( $display );

		$maxKey = max( array_map( 'strlen', array_keys( $display ) ) );
		$home = $this->hd;

		$this->helpers->msg( sprintf( "\n%s (%d):\n", $msg, count( $display ) ), 'green' );

		$cyan  = $this->helpers->color( 'cyan' );
		$gray  = $this->helpers->color( 'dark_gray' );
		$reset = $this->helpers->color( 'none' );

		foreach ( $display as $key => $dir ) {
			$shortDir = 0 === strpos( $dir, $home )
				? '~' . substr( $dir, strlen( $home ) )
				: $dir;
			$padding = str_repeat( ' ', $maxKey - strlen( $key ) );
			echo sprintf( "  %s%s%s%s  =>  %s%s%s\n", $cyan, $key, $reset, $padding, $gray, $shortDir, $reset );
		}

		$this->helpers->msg( '' );

		return $this;
	}
}

function commands( DirMap $dirmap ) {
	$methods = get_class_methods( $dirmap );
	$key     = array_search( '__construct', $methods );

	unset( $methods[ $key ] );

	return $methods;
}

$cli = require_once dirname(__DIR__) . '/src/bootstrap.php';
$helpyHelperton = $cli->getHelp();

$helpyHelperton
	->setScriptName( 'dirmap' )
	->setDescription( 'Stores shortcuts for directories (a map), making it easier to bookmark and navigate to directories on the drive.' )
	->setupDefaultCommand( [
		'<key>' => 'The directory map key (alias) to navigate to.',
	] )
	->setup( 'dirmap', [
		'add' => [
			'[<key>] [<path>]',
			'Add a new directory mapping. Key defaults to the current directory name, and path to the current directory, if omitted.',
			'<key>    The alias for this directory (defaults to current directory name)',
			'<path>   The directory path (defaults to current directory)',
		],
		'rename' => [
			'[<oldkey>] <newkey>',
			'Rename an existing mapping. If oldkey is omitted, the current directory is identified to find it.',
			'<oldkey>   The existing alias (defaults to the key for the current directory)',
			'<newkey>   The new alias',
		],
		'remove' => [
			'<key>',
			'Remove an existing directory mapping.',
			'<key>   The alias to remove',
		],
		'get' => [
			'<key>',
			'Get the path for a directory map key (same as `dirmap <key>`).',
			'<key>   The alias to look up',
		],
		'identify' => [
			'[<path>]',
			'Show the dirmap key for a directory. Defaults to the current directory.',
			'<path>   The directory path to identify (defaults to current directory)',
		],
		'list' => [
			'[--keys|-k] [--json|-j]',
			'Output the stored directory map.',
			'-k, --keys   Output only the map keys',
			'-j, --json   Output raw JSON (pipe-friendly, no colors)',
		],
		'edit' => [
			'',
			'Open the directory-map file (~/.dirmap.json) in your editor.',
		],
	] );

$dirmap  = new DirMap( $cli );
$command = $cli->getArg( 1, '' );

if ( $helpyHelperton->batSignal ) {
	$cli->msg( $helpyHelperton->getHelp( $command ) );
	exit( 0 );
}

if ( 'commands' === $command ) {
	exit( implode("\n", commands( $dirmap ) ) );
}

if ( 'get' === $command ) {
	// Shift so get() reads the key from the right position.
	array_splice( $cli->args, 1, 1 );
	return $dirmap->get();
}

if ( is_callable( [ $dirmap, $command ] ) ) {
	return $dirmap->{$command}( $cli->args );
}

$dirmap->get();
